<!-- views/manager-dashboard.ejs -->
<!<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manager Dashboard</title>
    <style>
        /* --- Global Styles --- */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            background-color: #020f2c;
            color: white;
            min-height: 100vh;
            padding-bottom: 50px;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }

        /* --- Header Section --- */
        .manage-header {
            background: #172133;
            padding: 25px 30px;
            border-radius: 12px;
            margin-bottom: 25px;
            box-shadow: 0 2px 6px rgba(0, 0, 0, 0.5);
        }

        .manage-header h1 {
            font-size: 28px;
            font-weight: 700;
            color: white;
        }

        .manage-header p {
            color: #9ca3af;
            font-size: 14px;
            margin-top: 5px;
        }

        /* --- Stats Grid --- */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 20px;
            margin-bottom: 25px;
        }

        .stat-card {
            background: #172133;
            padding: 30px;
            border-radius: 12px;
            border-bottom: 4px solid #3b82f6;
        }

        .stat-card.pending {
            border-bottom-color: #f59e0b;
        }

        .stat-card.progress {
            border-bottom-color: #10b981;
        }

        .stat-card.resolved {
            border-bottom-color: #6366f1;
        }

        .stat-number {
            font-size: 32px;
            font-weight: 800;
            color: white;
            margin-bottom: 5px;
            text-align: center;
        }

        .stat-label {
            font-size: 12px;
            font-weight: 600;
            color: #9ca3af;
            text-transform: uppercase;
            text-align: center;
        }

        /* --- Filter Bar --- */
        .filter-bar {
            background: #172133;
            padding: 20px 25px;
            border-radius: 12px;
            margin-bottom: 25px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 2px 6px rgba(0, 0, 0, 0.5);
        }

        .filters {
            display: flex;
            gap: 20px;
            align-items: center;
        }

        .filter-group label {
            font-size: 14px;
            font-weight: 600;
            color: #9ca3af;
            margin-right: 10px;
        }

        .filter-group select {
            padding: 8px 12px;
            border: 1px solid #4b5563;
            border-radius: 6px;
            background: #0f172a;
            color: white;
            cursor: pointer;
        }

        .showing-text {
            font-size: 14px;
            color: #9ca3af;
        }

        /* ===== Dark Background & Card ===== */
body {
    background-color: #0f172a; /* dark background base */
    color: #e2e8f0; /* light text */
}

/* Complaint card */
.complaint-card {
    background: #172133; /* deep navy/dark slate */
    border-radius: 12px;
    margin-bottom: 20px;
    border: 1px solid #334155; /* subtle border for depth */
}

/* Card body spacing */
.complaint-card h4 {
    font-size: 1.25rem;
    color: #f1f5f9; /* light text */
    margin-bottom: 8px;
}

.complaint-card p {
    font-size: 15px;
    color: #cbd5e1; /* slightly muted text */
    margin: 4px 0;
}

/* Votes summary */
.votes-summary {
    padding: 8px 0;
    color: #94a3b8; /* medium gray text */
}

/* Comments section */
.comments-section {
    background: #1e293b; /* darker surface */
    padding: 8px;
    border-radius: 6px;
    margin-top: 10px;
}

.comments-section ul li {
    padding: 6px 0;
    border-bottom: 1px solid #334155;
    color: #e2e8f0;
}

.comments-section p {
    color: #64748b;
}

/* Management Reply Box */
.management-reply-box {
    background: #1e293b; /* dark surface */
    border-left: 4px solid #22c55e; /* green accent */
    padding: 15px;
    margin: 15px 0;
    border-radius: 4px;
}

.management-reply-box h4 {
    color: #a5d6a7; /* soft green label */
    font-size: 0.9rem;
}

.management-reply-box p {
    color: #d1fae5; /* light green text */
}

/* Manager Action Buttons */
.manager-actions button,
.manager-actions form button {
    background: #0f172a;
    border: 1px solid #334155;
    padding: 8px 12px;
    color: #ffffff;
    border-radius: 6px;
    cursor: pointer;
    transition: background 0.2s;
}

.manager-actions button:hover,
.manager-actions form button:hover {
    background: #1e293b;
}

/* Expandable Update Section */
.status-update-box {
    background: #1e293b;
    border: 1px solid #334155;
    border-radius: 10px;
    padding: 20px;
    margin-top: 15px;
}

/* Update form inputs */
.status-update-box input[type="text"],
.status-update-box textarea {
    width: 100%;
    background: #0f172a;
    border: 1px solid #334155;
    color: #e2e8f0;
    border-radius: 6px;
    padding: 10px;
    margin-top: 8px;
    font-size: 15px;
}

/* Buttons in update section */
.status-update-box .btn-save {
    background: #22c55e; /* green accent */
    color: white;
    padding: 10px 18px;
    border-radius: 6px;
}

.status-update-box .btn-save:hover {
    background: #16a34a;
}

.status-update-box .btn-cancel {
    background: #64748b; /* muted gray */
    color: white;
    padding: 10px 18px;
    border-radius: 6px;
}

.status-update-box .btn-cancel:hover {
    background: #475569;
}
    </style>
</head>

<body>
    <%- include("../partials/managerHeader", { user: user }) %>

    <div class="container">
        <!-- Header -->
        <div class="manage-header">
            <h1>Manage Complaints</h1>
            <p>View and manage all student complaints</p>
        </div>

        <!-- Stats Grid -->
        <div class="stats-grid">
            <div class="stat-card a">
                <div class="stat-number"><%= complaints.length %></div>
                <div class="stat-label">Total</div>
            </div>
            <div class="stat-card b">
                <div class="stat-number"><%= complaints.filter(c => c.status === 'pending').length %></div>
                <div class="stat-label">Pending</div>
            </div>
            <div class="stat-card c">
                <div class="stat-number"><%= complaints.filter(c => c.status === 'inProgress').length %></div>
                <div class="stat-label">In Progress</div>
            </div>
            <div class="stat-card d">
                <div class="stat-number"><%= complaints.filter(c => c.status === 'resolved').length %></div>
                <div class="stat-label">Resolved</div>
            </div>
        </div>

        <!-- Filter Bar -->
        <div class="filter-bar">
            <div class="filters">
                <div class="filter-group">
                    <label>Category:</label>
                    <select>
                        <option>All</option>
                        <% const categories=[...new Set(complaints.map(c=> c.category))];
                        categories.forEach(cat => { %>
                        <option><%= cat %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="filter-group">
                    <label>Status:</label>
                    <select>
                        <option>All</option>
                        <option>Pending</option>
                        <option>In Progress</option>
                        <option>Resolved</option>
                    </select>
                </div>
            </div>
       </div>
            <%- include("../partials/complainCard", { 
    complaints: complaints, 
    user: user, 
    currentPage: currentPage 
}) %>
           
</body>

</html>