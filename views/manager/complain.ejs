<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Complaint Feed</title>

    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Inter', sans-serif; }

        body {
            background-color: #0b1120;
            color: white;
            min-height: 100vh;
        }

        .container { max-width: 1200px; margin: 30px auto; }

        .feed-header {
            display: flex;
            justify-content: space-between;
            background: #172133;
            padding: 20px;
            border-radius: 12px;
            margin-bottom: 20px;
        }

        .btn-post-main {
            background: #3b82f6;
            padding: 10px 20px;
            border-radius: 8px;
            border: none;
            color: white;
        }

    </style>
</head>

<body>

 <%- include("../partials/managerHeader", { user: user }) %>

<div class="container">

    <!-- LOOP-->
    
<%- include("../partials/complainCard", { 
    complaints: complaints, 
    user: user, 
    currentPage: currentPage 
}) %>

<% if (complaints.length === 0) { %>
    <p>No complaints found</p>
<% } %>

</div>

</body>
</html>