<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>feedback</title>
    <style>
        body {
    margin: 0;
    font-family: 'Segoe UI';
    background: linear-gradient(135deg, #020f2c);
    color: white;
}

/* Container */
.container {
    padding: 30px;
}

/* Header */
.header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: #1e293b;
    padding: 20px;
    border-radius: 10px;
}

/* Buttons */
.btn-primary {
    background: #2563eb;
    padding: 10px 15px;
    border-radius: 6px;
    color: white;
    text-decoration: none;
}

.btn-secondary {
    background: #475569;
    padding: 10px 15px;
    border-radius: 6px;
    color: white;
    text-decoration: none;
}

.btn-success {
    background: #22c55e;
    padding: 10px;
    border: none;
    border-radius: 6px;
    color: white;
}

/* Empty */
.empty {
    text-align: center;
    margin-top: 80px;
    opacity: 0.8;
}

/* Form */
.form-card {
    background: #1e293b;
    padding: 30px;
    border-radius: 12px;
    width: 400px;
    margin: 40px auto;
}

.form-card input,
.form-card textarea {
    width: 100%;
    margin-bottom: 15px;
    padding: 10px;
    border-radius: 6px;
    border: none;
}

/* Poll Cards */
.poll-container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 350px));
    justify-content: start;
    gap: 20px;
    margin-top: 20px;
    align-items: start;
}

.poll-card {
    background: #1e293b;
    padding: 20px;
    border-radius: 12px;
    width: 300px;
    box-shadow: 0 10px 25px rgba(0,0,0,0.4);
}


.poll-card:hover {
    transform: translateY(-5px);
    transition: 0.3s;
}

.stats {
    display: flex;
    justify-content: space-between;
    margin: 15px 0;
}

.status {
    color: #22c55e;
    margin-bottom: 10px;
}

/* Buttons */
.actions button {
    margin-right: 5px;
    padding: 6px 10px;
    border: none;
    border-radius: 6px;
    cursor: pointer;
}

.btn-view {
    background: #3b82f6;
    color: white;
}

.btn-warn {
    background: #f59e0b;
}

.btn-danger {
    background: #ef4444;
    color: white;
}

/* Modal */
.modal {
    display: none;
    position: fixed;
    top:0; left:0;
    width:100%;
    height:100%;
    background: rgba(0,0,0,0.6);
    justify-content: center;
    align-items: center;
}

.modal-content {
    background: #1e293b;
    width: 600px;
    max-height: 80vh;
    overflow-y: auto;
    padding: 20px;
    border-radius: 12px;
    color: white;
}

/* Header */
.modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

/* Stats */
.stats-box {
    display: flex;
    justify-content: space-between;
    margin: 20px 0;
}

.stats-box h1 {
    color: #60a5fa;
}

/* Bars */
.bar-row {
    display: flex;
    align-items: center;
    margin: 8px 0;
}

.bar {
    flex: 1;
    height: 10px;
    background: #334155;
    margin: 0 10px;
    border-radius: 10px;
    overflow: hidden;
}

.fill {
    height: 100%;
    background: linear-gradient(90deg, #3b82f6, #8b5cf6);
}

/* Feedback */
.fb-card {
    background: #0f172a;
    padding: 10px;
    border-radius: 8px;
    margin-top: 10px;
}

select {
    width: 100%;
    padding: 10px;
    border-radius: 8px;
    border: none;
    background: #0f172a;
    color: white;
    margin-bottom: 15px;
}
    </style>
</head>
<body>

    <%- include("../partials/managerHeader", { user: user }) %>
    <div class="container">

    <!-- HEADER -->
    <div class="header">
        <h1>Manage Feedback Polls</h1>

        <% if (!showForm) { %>
            <a href="/create-poll" class="btn-primary">+ Create New Poll</a>
        <% } else { %>
            <a href="/feedback" class="btn-secondary">Cancel</a>
        <% } %>
    </div>

    <!-- EMPTY STATE -->
    <% if (!showForm && polls.length === 0) { %>
        <div class="empty">
            <h2>Empty</h2>
            <p>No Polls Yet</p>
        </div>
    <% } %>

    <!-- CREATE FORM -->
    <% if (showForm) { %>
        <div class="form-card">
            <h2>Create New Poll</h2>

<form action="/create-poll" method="POST">

    <!-- Title -->
   <input type="text" name="title" placeholder="Poll Title" required autofocus />

    <!-- Description -->
    <textarea  name="description"  placeholder="Description"  required></textarea>

    <!-- Category -->
    <input type="text" name="category" value="General" placeholder="Category"/>


    <!-- Submit -->
    <button type="submit" class="btn-success">Create Poll </button>

           </form>
        </div>
    <% } %>

    <!-- POLL CARDS -->
    <% if (!showForm && polls.length > 0) { %>
        <div class="poll-container">
            <% polls.forEach(p => { %>
                <div class="poll-card">
                    <h3><%= p.title %></h3>
                    <p><%= p.description %></p>

                    <div class="stats">
                        <span><%= Number(p.avg).toFixed(2) %> Avg</span>
                        <span><%= p.total %> Ratings</span>
                    </div>

                    <div class="status">Active</div>

                   <div class="actions">

    <!-- VIEW -->
    <button onclick="viewResults('<%= p.id %>', '<%= p.title %>')" class="btn-view">
    View Results
</button>

    <!-- DEACTIVATE -->
    <form action="/deactivate-poll/<%= p.id %>" method="POST" style="display:inline;">
        <button class="btn-warn">Deactivate</button>
    </form>

    <!-- DELETE -->
    <form action="/delete-poll/<%= p.id %>" method="POST" style="display:inline;">
        <button class="btn-danger">Delete</button>
    </form>
</div>

                </div>
            <% }) %>
        </div>
    <% } %>

</div>

<div id="resultModal" class="modal">
    <div class="modal-content">

        <div class="modal-header">
            <h2 id="modal-title"></h2>
            <button onclick="closeModal()">Close</button>
        </div>

        <div class="stats-box">
            <div>
                <h1 id="avg">0.00</h1>
                <p>Average Rating</p>
                <div id="avg-stars"></div>
            </div>

            <div>
                <h1 id="total">0</h1>
                <p>Total Responses</p>
            </div>
        </div>

        <h3>Rating Distribution</h3>
        <div id="distribution"></div>

        <h3>Recent Feedback</h3>
        <div id="feedback-list"></div>

    </div>
</div>


<script>
function viewResults(id, title){
    fetch("/poll-results/" + id)
    .then(res => res.json())
    .then(data => {

        document.getElementById("resultModal").style.display = "flex";
        document.getElementById("modal-title").innerText = title;

        //  avg 
        let avg = Number(data.avg) || 0;
        let total = Number(data.total) || 0;

        document.getElementById("avg").innerText = avg.toFixed(2);
        document.getElementById("total").innerText = total;

        //  stars
        let starsHTML = "";
        for(let i=1;i<=5;i++){
            starsHTML += i <= Math.round(avg) ? "⭐" : "☆";
        }
        document.getElementById("avg-stars").innerHTML = starsHTML;

        //  distribution (safe handling)
        let distHTML = "";
        for(let i=5;i>=1;i--){
            let count = (data.distribution && data.distribution[i]) ? data.distribution[i] : 0;
            let percent = total ? (count / total * 100) : 0;

            distHTML += `
                <div class="bar-row">
                    <span>${i} ⭐</span>
                    <div class="bar">
                        <div class="fill" style="width:${percent}%"></div>
                    </div>
                    <span>${count}</span>
                </div>
            `;
        }
        document.getElementById("distribution").innerHTML = distHTML;

        // feedback (empty safe)
        let fbHTML = "";

        if (!data.feedback || data.feedback.length === 0) {
            fbHTML = "<p>No feedback yet</p>";
        } else {
            data.feedback.forEach(f => {
                let stars = "⭐".repeat(f.rating);

                fbHTML += `
                    <div class="fb-card">
                        <div>${stars}</div>
                        <p>${f.comment || "No comment"}</p>
                    </div>
                `;
            });
        }

        document.getElementById("feedback-list").innerHTML = fbHTML;
    })
    .catch(err => {
        console.log("Error:", err);
    });
}

function closeModal(){
    document.getElementById("resultModal").style.display = "none";
}
</script>
</body>
</html>
