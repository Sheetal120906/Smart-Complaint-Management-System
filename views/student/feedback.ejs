<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>feedback</title>

<style>
body {
    margin: 0;
    font-family: 'Segoe UI';
    background: linear-gradient(135deg, #020f2c, #020617);
    color: white;
}

/* Container */
.container {
    padding: 30px;
}

/* Grid */
.poll-container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 350px));
    justify-content: start;
    gap: 60px;
    margin-top: 20px;
    align-items: start;
}

/* Card */
.poll-card {
    background: rgba(30, 41, 59, 0.6);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.08);
    padding: 22px;
    border-radius: 18px;
    width: 100%;
    max-width: 350px;
    box-shadow: 0 15px 35px rgba(0,0,0,0.5);
    transition: 0.3s;
    position: relative;
    overflow: visible;   /* ✅ FIX */
}

/* Hover */
.poll-card:hover {
    transform: translateY(-8px);
}

/* Title */
.poll-card h3 {
    margin: 0;
    font-size: 20px;
    color: #e2e8f0;
}

/* Description */
.poll-card p {
    font-size: 14px;
    color: #94a3b8;
}

/* Button */
.btn-primary {
    background: linear-gradient(135deg, #3b82f6, #6366f1);
    padding: 10px 16px;
    border-radius: 8px;
    border: none;
    color: white;
    cursor: pointer;
}

/* Rating Box */
.rate-box {
    display: none; /* cleaner */
    background: rgba(15, 23, 42, 0.9);
    padding: 15px;
    border-radius: 12px;
    margin-top: 15px;
}

/* Stars */
.stars {
    margin: 12px 0;
    text-align: center;
}

.stars span {
    cursor: pointer;
    font-size: 30px;
    margin: 0 5px;
    opacity: 0.3;
    transition: all 0.2s ease;
}

/* Only clicked stars glow */
.active-star {
    color: gold !important;
    opacity: 1 !important;
}

/* Optional small hover effect (no glow) */
.stars span:hover {
    transform: scale(1.2);
}

/* Textarea */
textarea {
    width: 100%;
    padding: 10px;
    border-radius: 8px;
    background: #020617;
    color: white;
    border: none;
    margin-top: 10px;
}

/* Buttons */
button[type="submit"] {
    margin-top: 10px;
    background: green;
    color: white;
    padding: 8px;
    border: none;
    border-radius: 6px;
}

button[type="button"] {
    background: gray;
    color: white;
    padding: 8px;
    border: none;
    border-radius: 6px;
}
</style>
</head>

<body>

<%- include("../partials/header") %>

<div class="container">

<div class="header">
    <h1>Feedback Polls</h1>
</div>

<div class="poll-container">

<% polls.forEach(p => { %>

<div class="poll-card">

    <h3><%= p.title %></h3>
    <p><%= p.description %></p>

    <!-- ✅ FIXED BUTTON -->
  <% if (p.rating != null) { %>
    <button onclick="openRating('<%= p.id %>')" class="btn-primary">
        Edit Feedback 
    </button>
<% } else { %>
    <button onclick="openRating('<%= p.id %>')" class="btn-primary">
        Rate Now
    </button>
<% } %>

    <!-- Rating Box -->
    <div id="rate-box-<%= p.id %>" class="rate-box">

        <form action="/submit-rating/<%= p.id %>" method="POST">

            <div class="stars">
               <% for(let i=1;i<=5;i++){ %>
    <span 
    onclick="setRating('<%= i %>', '<%= p.id %>')" 
    class="<%= (p.rating && p.rating >= i) ? 'active-star' : '' %>">
    ⭐
</span>
<% } %>
            </div>

            <input type="hidden" name="rating" id="rating-<%= p.id %>" value="<%= p.rating || 0 %>">

            <textarea name="comment"><%= p.comment || "" %></textarea>

           <button type="submit" onclick="return checkRating('<%= p.id %>')">Submit</button>
            <button type="button" onclick="openRating('<%= p.id %>')">Cancel</button>

        </form>
    </div>

</div>

<% }) %>

</div>
</div>


<script>
function openRating(id){
    const box = document.getElementById("rate-box-" + id);
    if (!box) return;

    box.style.display = (box.style.display === "block") ? "none" : "block";
}

function checkRating(id){
    const value = document.getElementById("rating-" + id).value;

    if(value == 0){
        alert("Please select rating ⭐");
        return false;
    }
    return true;
}

function setRating(value, id){
    value = parseInt(value);

    document.getElementById("rating-" + id).value = value;

    const stars = document.querySelectorAll("#rate-box-" + id + " span");

    stars.forEach((star, index) => {
        if (index < value) {
            star.classList.add("active-star");
        } else {
            star.classList.remove("active-star");
        }
    });
}

/*  ADD THIS PART (hover effect) */
document.addEventListener("DOMContentLoaded", () => {

    document.querySelectorAll(".stars").forEach(starContainer => {

        const stars = starContainer.querySelectorAll("span");

        stars.forEach((star, index) => {

            // Hover preview
            star.addEventListener("mouseover", () => {
                stars.forEach((s, i) => {
                    s.classList.toggle("active-star", i <= index);
                });
            });

            // Restore selected rating on mouse leave
            starContainer.addEventListener("mouseleave", () => {
                const input = starContainer.parentElement.querySelector("input");
                const savedValue = parseInt(input.value) || 0;

                stars.forEach((s, i) => {
                    s.classList.toggle("active-star", i < savedValue);
                });
            });

        });
    });

});

function alreadyDone(){
    alert("You have already submitted feedback for this poll ");
}
</script>

</body>
</html>