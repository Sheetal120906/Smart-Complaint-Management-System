<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <style>
        .complaint-card {
    background: #172133;
    border-radius: 12px;
    margin-bottom: 20px;
}

.complaint-card:hover {
    transform: translateY(-2px);
    transition: 0.2s;
}
.card-body { padding: 20px; }

.tag {
    padding: 4px 10px;
    border-radius: 20px;
    font-size: 11px;
}

.tag-dept { background: #475569; }


.tag-pending {
    background: #f59e0b;
    color: black;
}

.tag-inProgress {
    background: #38bdf8;
    color: black;
}

.tag-resolved {
    background: #22c55e;
    color: white;
}


.interaction-bar {
    padding: 10px;
    background: #1e293b;
    display: flex;
    gap: 10px;
    align-items: center;
}


.btn-vote {
    background: #0f172a;
    border: 1px solid #334155;
    padding: 5px 10px;
    color: white;
    cursor: pointer;
    border-radius: 6px;
}

.btn-vote:hover {
    background: #1e293b;
}

.comment-box {
    padding: 10px;
    display: flex;
    flex-direction: column;
    gap: 10px;
}

.comment-form {
    display: flex;
    gap: 8px;
}

.comment-form input {
    flex: 1;
    padding: 8px;
    background: #0f172a;
    border: 1px solid #334155;
    color: white;
    border-radius: 6px;
}

.comment-form button {
    padding: 8px 12px;
    background: #38bdf8;
    border: none;
    border-radius: 6px;
    cursor: pointer;
}

.comment-form button:hover {
    background: #0ea5e9;
}

.comments-section {
    background: #020f2c;
    padding: 10px;
    border-radius: 6px;
}

.comment {
    padding: 6px 0;
    border-bottom: 1px solid #334155;
    color: #e2e8f0;
}

.no-comment {
    color: #64748b;
}

.btn-delete {
    background: #ef4444;
    color: white;
    border: none;
    padding: 5px 10px;
    border-radius: 6px;
    cursor: pointer;
}

.btn-delete:hover {
    background: #dc2626;
}

/* RESPONSE BOX */
.response-box {
    background: #022c22;              
    border-left: 5px solid #22c55e;   
    padding: 12px;
    border-radius: 6px;
    margin-top: 10px;
}

.response-box strong {
    color: #4ade80;
    display: block;
    margin-bottom: 5px;
}

.response-box p {
    color: #d1fae5;
    margin: 0;
}
    </style>
</head>
<body>
    <% complaints.forEach(function(c){ %>

<div class="complaint-card">
<div class="card-body">

<!-- HEADER -->
<div style="display:flex; justify-content:space-between; align-items:center;">
    <div>
        <span class="tag tag-dept"><%= c.category %></span>

        <!-- STATUS COLOR -->
        <span class="tag 
    <%= c.status === 'pending' ? 'tag-pending' : '' %>
    <%= c.status === 'in-progress' ? 'tag-progress' : '' %>
    <%= c.status === 'resolved' ? 'tag-resolved' : '' %>
">
    <%= c.status === "in-progress" ? "In Progress" : 
         c.status.charAt(0).toUpperCase() + c.status.slice(1) %>
</span>
    </div>

    <div style="display:flex; gap:10px; align-items:center;">
        <span>
            <%= new Date(c.date).toLocaleDateString('en-IN', {
                day: 'numeric',
                month: 'short',
                year: 'numeric'
            }) %>
        </span>

        <% if (user.roll === c.student || user.role === "manager") { %>
        <form action="/delete-complaint/<%= c.id %>" method="POST">
            <button class="btn-delete">Delete</button>
        </form>
        <% } %>
    </div>
</div>

<!-- TITLE -->
<h3 style="margin-top:10px; color:#38bdf8;"><%= c.title %></h3>

<!-- DESCRIPTION -->
<p style="color:#e2e8f0;"><%= c.description %></p>

<!-- RESPONSE (FOR BOTH) -->
<% if (c.response) { %>
<div class="response-box">
    <strong>Management Response:</strong>
    <p><%= c.response %></p>
</div>
<% } %>

<!-- VOTING -->
<div class="interaction-bar">

<form action="/agree/<%= c.id %>" method="POST">
    <input type="hidden" name="redirectTo" value="<%= currentPage %>">
    <button class="btn-vote">👍 Agree (<%= c.agree %>)</button>
</form>

<form action="/disagree/<%= c.id %>" method="POST">
    <input type="hidden" name="redirectTo" value="<%= currentPage %>">
    <button class="btn-vote">👎 Disagree (<%= c.disagree %>)</button>
</form>

<span>Comments: <%= c.comments_count %></span>

</div>

<!-- COMMENTS -->
<div class="comment-box">

<form action="/add-comment/<%= c.id %>" method="POST" class="comment-form">
    <input type="hidden" name="redirectTo" value="<%= currentPage %>">
    <input type="text" name="comment" placeholder="Add comment..." required>
    <button type="submit">Post</button>
</form>

<button class="btn-vote" onclick="toggleComments('<%= c.id %>')">
    Show/Hide Comments
</button>

<div id="comments-<%= c.id %>" class="comments-section" style="display:none;">
    <% if (c.commentsList && c.commentsList.length > 0) { %>
        <% c.commentsList.forEach(function(cm){ %>
            <p class="comment"><%= cm %></p>
        <% }) %>
    <% } else { %>
        <p class="no-comment">No comments yet</p>
    <% } %>
</div>

</div>

<!-- MANAGER ONLY -->
<% if (user.role === "manager") { %>

<button onclick="toggleUpdateCard('<%= c.id %>')" class="btn-vote">
    Update Status
</button>

<div id="update-box-<%= c.id %>" style="display:none; margin-top:10px;">
<form action="/update-complaint-status/<%= c.id %>" method="POST">
<h3>Update Status:</h3>
<!--  DROPDOWN -->
<select name="status" required>
    <option value="pending" <%= c.status === "pending" ? "selected" : "" %>>Pending</option>
    <option value="inProgress" <%= c.status === "inProgress" ? "selected" : "" %>>In Progress</option>
    <option value="resolved" <%= c.status === "resolved" ? "selected" : "" %>>Resolved</option>
</select>
<h3>Management Response:</h3>
<textarea name="response" placeholder="Enter response..." style="width:100%; margin-top:5px;">
<%= c.response || "" %>
</textarea>

<button type="submit">Save</button>
<button type="button" onclick="toggleUpdateCard('<%= c.id %>')">Cancel</button>

</form>
</div>

<% } %>

</div>
</div>

<% }) %>

<script>
function toggleComments(id) {
    const box = document.getElementById("comments-" + id);
    box.style.display = (box.style.display === "none") ? "block" : "none";
}

function toggleUpdateCard(id) {
    const box = document.getElementById("update-box-" + id);
    box.style.display = (box.style.display === "none" || box.style.display === "") ? "block" : "none";
}
</script>
</body>
</html>